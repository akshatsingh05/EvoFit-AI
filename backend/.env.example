# --- Environment --------------------------------------------------------
# "development" | "staging" | "production"
ENVIRONMENT=development
DEBUG=true

# --- Database -------------------------------------------------------------
# Local/dev: SQLite (no setup required).
#   DATABASE_URL=sqlite:///./evofit.db
# Production: PostgreSQL (e.g. Neon, RDS, Render Postgres).
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./evofit.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Auth / JWT -------------------------------------------------------------
# Generate strong random values for these in every real environment, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
SECRET_KEY=change-this-to-a-different-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI providers (optional, unused today) ---------------------------------
# The app runs entirely on the built-in rule-based recommendation engine and
# makes no calls to either API. These are placeholders reserved for a future
# ClaudeProvider/ChatGPTProvider; leaving them blank is fully supported.
CLAUDE_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=rule_based

# --- CORS / hosts -------------------------------------------------------------
# Comma-separated. Must match the deployed frontend origin(s) exactly.
CORS_ORIGINS=http://localhost:5173
# Comma-separated list of allowed Host header values, or "*" to allow any.
# Set this to your real backend domain(s) in production.
TRUSTED_HOSTS=*
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- Rate limiting -------------------------------------------------------------
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT=10/minute
